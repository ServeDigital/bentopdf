# Gold Leaf Holdings — BentoPDF Branding
# Applied at build time via Vite + Handlebars

VITE_BRAND_NAME=eDMS PDF Tools
VITE_BRAND_LOGO=images/goldleaf_logo.png
VITE_FOOTER_TEXT=Gold Leaf Holdings — PDF Tools
SIMPLE_MODE=true

# WASM modules (CDN defaults)
VITE_WASM_PYMUPDF_URL=https://cdn.jsdelivr.net/npm/@bentopdf/pymupdf-wasm@0.11.16/
VITE_WASM_GS_URL=https://cdn.jsdelivr.net/npm/@bentopdf/gs-wasm/assets/
VITE_WASM_CPDF_URL=https://cdn.jsdelivr.net/npm/coherentpdf/dist/
